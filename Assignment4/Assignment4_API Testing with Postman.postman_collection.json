  "item": [
    {
      "name": "1. Register API Client (POST)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Task 3: Generate random data",
              "var ts = Date.now();",
              "var randomEmail = 'user' + ts + '@testmail.com';",
              "var randomClientName = 'Client_' + ts;",
              "pm.collectionVariables.set('randomEmail', randomEmail);",
              "pm.collectionVariables.set('randomClientName', randomClientName);",
              "console.log('Email: ' + randomEmail);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Task 4: Parse JSON and log",
              "var jsonData = pm.response.json();",
              "console.log('Register response: ' + JSON.stringify(jsonData));",
              "",
              "// Task 6: Save accessToken for chaining",
              "if (jsonData.accessToken) {",
              "    pm.collectionVariables.set('accessToken', jsonData.accessToken);",
              "    console.log('Token saved: ' + jsonData.accessToken);",
              "}",
              "",
              "// Task 5: Passing assertions",
              "pm.test('Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Response has accessToken', function () {",
              "    pm.expect(jsonData).to.have.property('accessToken');",
              "    pm.expect(jsonData.accessToken).to.be.a('string').and.not.empty;",
              "});",
              "pm.test('Response time under 5000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});",
              "",
              "// Task 5: *** INTENTIONAL FAILING TEST #1 ***",
              "pm.test('[FAILING TEST] Status should be 200 - intentional fail', function () {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientName\": \"{{randomClientName}}\",\n  \"clientEmail\": \"{{randomEmail}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api-clients/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api-clients",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Get All Books (GET)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "console.log('Fetching books from: ' + pm.collectionVariables.get('baseUrl'));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "console.log('Books count: ' + jsonData.length);",
              "console.log('First book: ' + JSON.stringify(jsonData[0]));",
              "",
              "// Task 7: Save first available bookId for chaining",
              "for (var i = 0; i < jsonData.length; i++) {",
              "    if (jsonData[i].available === true) {",
              "        pm.collectionVariables.set('bookId', String(jsonData[i].id));",
              "        console.log('bookId saved: ' + jsonData[i].id);",
              "        break;",
              "    }",
              "}",
              "",
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is an array', function () {",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "pm.test('Every book has id and name', function () {",
              "    jsonData.forEach(function(book) {",
              "        pm.expect(book).to.have.property('id');",
              "        pm.expect(book).to.have.property('name');",
              "    });",
              "});",
              "pm.test('At least one book is available', function () {",
              "    var avail = jsonData.filter(function(b) { return b.available === true; });",
              "    pm.expect(avail.length).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/books",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "books"
          ]
        }
      },
      "response": []
    },
