        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "console.log('Book: ' + JSON.stringify(jsonData));",
              "console.log('Name: ' + jsonData.name);",
              "console.log('Type: ' + jsonData.type);",
              "console.log('Available: ' + jsonData.available);",
              "",
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Book id matches chained bookId', function () {",
              "    pm.expect(String(jsonData.id)).to.eql(pm.collectionVariables.get('bookId'));",
              "});",
              "pm.test('Book has name and type', function () {",
              "    pm.expect(jsonData).to.have.property('name');",
              "    pm.expect(jsonData).to.have.property('type');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/books/{{bookId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "books",
            "{{bookId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. Submit Order (POST – Chained bookId & Token)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Task 3: Random customer name",
              "var names = ['Ahmed Khan', 'Sara Malik', 'Ali Hassan', 'Maria Jones', 'Omar Qureshi'];",
              "var name = names[Math.floor(Math.random() * names.length)];",
              "pm.collectionVariables.set('randomName', name);",
              "console.log('Customer: ' + name);",
              "console.log('bookId: ' + pm.collectionVariables.get('bookId'));",
              "console.log('token: ' + pm.collectionVariables.get('accessToken'));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "console.log('Order response: ' + JSON.stringify(jsonData));",
              "",
              "// Task 6: Save orderId for chaining",
              "if (jsonData.orderId) {",
              "    pm.collectionVariables.set('orderId', jsonData.orderId);",
              "    console.log('orderId saved: ' + jsonData.orderId);",
              "}",
              "",
              "pm.test('Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Order created is true', function () {",
              "    pm.expect(jsonData.created).to.be.true;",
              "});",
              "pm.test('Response has orderId', function () {",
              "    pm.expect(jsonData).to.have.property('orderId');",
              "    pm.expect(jsonData.orderId).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookId\": {{bookId}},\n  \"customerName\": \"{{randomName}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "orders"
          ]
        }
      },
