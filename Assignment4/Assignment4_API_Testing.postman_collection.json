      "name": "1. Register API Client (POST)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Clear stale token from any previous run (Glitch resets tokens on restart)",
              "pm.collectionVariables.set('accessToken', '');",
              "pm.collectionVariables.set('orderId', '');",
              "pm.collectionVariables.set('bookId', '');",
              "",
              "// Task 3: Generate random request body data",
              "const randomNum = Math.floor(Math.random() * 100000);",
              "const randomEmail = `testuser${randomNum}@example.com`;",
              "const randomClientName = `TestClient_${randomNum}`;",
              "",
              "// Store for use in request body",
              "pm.collectionVariables.set('randomEmail', randomEmail);",
              "pm.collectionVariables.set('randomClientName', randomClientName);",
              "",
              "console.log('Generated Email:', randomEmail);",
              "console.log('Generated Client Name:', randomClientName);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Task 4: Parse JSON response and log values",
              "const jsonData = pm.response.json();",
              "console.log('Full Response:', JSON.stringify(jsonData));",
              "",
              "// Task 6: Use Tests section for variable handling",
              "if (jsonData.accessToken) {",
              "    pm.collectionVariables.set('accessToken', jsonData.accessToken);",
              "    console.log('Access Token saved:', jsonData.accessToken);",
              "} else {",
              "    console.error('CRITICAL: No accessToken in response! Body:', JSON.stringify(jsonData));",
              "}",
              "",
              "// Task 5: Chai assertions",
              "pm.test('Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has accessToken', function () {",
              "    pm.expect(jsonData).to.have.property('accessToken');",
              "    pm.expect(jsonData.accessToken).to.be.a('string');",
              "});",
              "",
              "pm.test('Response time is less than 3000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});",
              "",
              "// Task 5: INTENTIONAL FAILING test case",
              "pm.test('[FAILING TEST] Status code should be 200 (intentional fail to demonstrate failing test case)', function () {",
              "    pm.expect(pm.response.code).to.eql(200); // Will fail because actual is 201",
