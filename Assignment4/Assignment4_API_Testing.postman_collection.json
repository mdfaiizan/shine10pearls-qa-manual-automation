      "name": "2. Get All Books (GET)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Task 6: Pre-request script – log before request",
              "console.log('Fetching all books from:', pm.collectionVariables.get('baseUrl'));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Task 4: Parse JSON response and log values",
              "const jsonData = pm.response.json();",
              "console.log('Total books returned:', jsonData.length);",
              "console.log('First book:', JSON.stringify(jsonData[0]));",
              "",
              "// Task 6: Save first available book ID for chaining (Task 7)",
              "const availableBook = jsonData.find(book => book.available === true);",
              "if (availableBook) {",
              "    pm.collectionVariables.set('bookId', availableBook.id);",
              "    console.log('Saved bookId for chaining:', availableBook.id);",
              "}",
              "",
              "// Task 5: Chai assertions",
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array', function () {",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "pm.test('Each book has id and name', function () {",
              "    jsonData.forEach(function(book) {",
              "        pm.expect(book).to.have.property('id');",
              "        pm.expect(book).to.have.property('name');",
              "    });",
              "});",
              "",
              "pm.test('At least one book is available', function () {",
              "    const available = jsonData.filter(b => b.available === true);",
              "    pm.expect(available.length).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
