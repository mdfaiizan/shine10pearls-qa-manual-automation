      "name": "4. Submit Order (POST – Chained bookId & Token)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// GUARD: Skip request if required chained variables are missing",
              "const _token = pm.collectionVariables.get(\"accessToken\");",
              "const _bId   = pm.collectionVariables.get(\"bookId\");",
              "if (!_token) {",
              "    console.error(\"SKIPPING: accessToken is empty. Request 1 must run first and succeed.\");",
              "    pm.execution.skipRequest();",
              "}",
              "if (!_bId) {",
              "    console.error(\"SKIPPING: bookId is empty. Request 2 must run first and succeed.\");",
              "    pm.execution.skipRequest();",
              "}",
              "",
              "// Task 3: Generate random customer name",
              "const firstNames = ['Ahmed', 'Sara', 'Ali', 'Maria', 'John', 'Zara'];",
              "const lastNames = ['Khan', 'Smith', 'Malik', 'Jones', 'Hassan', 'Ali'];",
              "const randomFirst = firstNames[Math.floor(Math.random() * firstNames.length)];",
              "const randomLast = lastNames[Math.floor(Math.random() * lastNames.length)];",
              "const fullName = `${randomFirst} ${randomLast}`;",
              "",
              "pm.collectionVariables.set('randomName', fullName);",
              "console.log('Ordering as customer:', fullName);",
              "",
              "// Task 7: Chaining – log the chained variables being used",
              "console.log('Using chained bookId:', pm.collectionVariables.get('bookId'));",
              "console.log('Using chained accessToken:', pm.collectionVariables.get('accessToken'));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Task 4: Parse JSON and log",
              "const jsonData = pm.response.json();",
              "console.log('Order response:', JSON.stringify(jsonData));",
              "",
              "// Task 6: Save orderId for chaining into next requests",
              "if (jsonData.orderId) {",
              "    pm.collectionVariables.set('orderId', jsonData.orderId);",
              "    console.log('Saved orderId:', jsonData.orderId);",
              "} else {",
              "    console.error('WARNING: No orderId returned. Downstream PUT/PATCH/DELETE will fail.');",
              "}",
              "",
              "// Task 5: Chai assertions",
              "pm.test('Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response contains orderId', function () {",
              "    pm.expect(pm.response.code).to.eql(201, 'Expected 201 – check accessToken is set');",
              "    pm.expect(jsonData).to.have.property('orderId');",
              "    pm.expect(jsonData.orderId).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
